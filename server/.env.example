# SQLite database file (relative to the server/ directory)
DB_URL="file:dev.db"

# Server
PORT=3001

# Admin auth: required in the x-admin-token header for /api/admin routes
ADMIN_TOKEN=change-me-to-a-long-random-string

# Admin notification recipient
ADMIN_EMAIL=msmigiel22@gmail.com

# SMTP (Nodemailer). Leave SMTP_HOST empty to log emails to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Football Tickets <no-reply@example.com>"
